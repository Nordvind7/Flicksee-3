# Flicksee API — copy to .env and fill in. Never commit .env.
PORT=3001

# TMDB (the API proxies TMDB so the key never reaches the browser).
TMDB_API_KEY=

# PostgreSQL. Postgres.app default = your macOS username, no password, port 5432.
DATABASE_URL=postgresql://YOUR_MAC_USER@localhost:5432/flicksee?schema=public

# Auth — secret for signing our own JWTs.
JWT_SECRET=

# Telegram bot token (from BotFather) — used to verify Login Widget signatures.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
