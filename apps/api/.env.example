# Flicksee API — copy to .env and fill in. Never commit .env.
# Locally use development. Production is the safe default if NODE_ENV is unset.
NODE_ENV=development
PORT=3001

# Dev-only auth shortcut (POST /auth/dev). Set "true" ONLY in development;
# the server refuses to boot if this is true while NODE_ENV=production.
ENABLE_DEV_LOGIN=true

# TMDB (the API proxies TMDB so the key never reaches the browser).
TMDB_API_KEY=

# PostgreSQL. Postgres.app default = your macOS username, no password, port 5432.
DATABASE_URL=postgresql://YOUR_MAC_USER@localhost:5432/flicksee?schema=public

# Auth — secret for signing our own JWTs.
JWT_SECRET=

# Telegram bot token (from BotFather) — used to verify Login Widget signatures.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Production only: the trusted web origin allowed to make credentialed CORS
# calls (e.g. https://flicksee.app). In dev the web server proxies /api.
WEB_ORIGIN=
