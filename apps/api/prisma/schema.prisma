// Flicksee data model.
// Postgres via Prisma. Designed for thousands of users: every hot query path
// is backed by an index, foreign keys cascade on user/room deletion, and the
// Content table caches TMDB so we never hammer the external API.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── Enums ─────────────────────────

enum ContentType {
  MOVIE
  TV
}

enum SwipeAction {
  LIKE // «хочу посмотреть»
  DISLIKE // «не интересно» — больше не показывать
  SEEN // «уже смотрел»
}

enum RoomStatus {
  ACTIVE
  CLOSED
}

enum MemberRole {
  HOST
  MEMBER
}

// ───────────────────────── Users & auth ─────────────────────────

model User {
  id           String   @id @default(cuid())
  // Telegram ids exceed 32-bit, so BigInt.
  telegramId   BigInt   @unique
  username     String?
  firstName    String?
  lastName     String?
  photoUrl     String?
  languageCode String?
  // Whether the user pressed /start in the bot — required before we can push
  // match notifications to them.
  isBotStarted Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastSeenAt   DateTime @default(now())

  swipes        Swipe[]
  refreshTokens RefreshToken[]
  hostedRooms   Room[]         @relation("RoomHost")
  roomMembers   RoomMember[]
  roomSwipes    RoomSwipe[]
  friendshipsA  Friendship[]   @relation("FriendshipA")
  friendshipsB  Friendship[]   @relation("FriendshipB")
  matchesA      Match[]        @relation("MatchA")
  matchesB      Match[]        @relation("MatchB")
  invites       Invite[]       @relation("InviteCreator")

  @@index([lastSeenAt])
}

// Refresh tokens for our own JWT auth. We store only a hash of the token.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ───────────────────────── Content cache ─────────────────────────

// Cache of TMDB titles: trailers, posters, RU watch-providers. Keyed by the
// natural (tmdbId, type) pair. This is a pure cache — swipes/matches store
// (tmdbId, contentType) and join here in app code, so a cache miss never
// blocks a write.
model Content {
  id               String      @id @default(cuid())
  tmdbId           Int
  type             ContentType
  title            String
  overview         String?
  posterPath       String?
  backdropPath     String?
  voteAverage      Float?
  releaseDate      String?
  genreIds         Int[]
  // Resolved trailer + where it came from (youtube | vk | rutube).
  trailerKey       String?
  trailerSource    String?
  trailerCheckedAt DateTime?
  // RU streaming availability from TMDB /watch/providers.
  providers        Json?
  // Raw TMDB payload, kept for forward-compatibility.
  payload          Json?
  fetchedAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([tmdbId, type])
  @@index([type])
}

// ───────────────────────── Personal swipes ─────────────────────────

// One row per (user, title): the user's current verdict. Re-swiping updates
// the action. Watchlist = LIKE, watched = SEEN, banned = DISLIKE.
model Swipe {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId      Int
  contentType ContentType
  action      SwipeAction
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([userId, tmdbId, contentType])
  // Fetch a user's watchlist / watched / banned lists by action, newest first.
  @@index([userId, action, createdAt])
  // Join to Content for display.
  @@index([tmdbId, contentType])
}

// ───────────────────────── Collaborative rooms ─────────────────────────

model Room {
  id          String      @id @default(cuid())
  // Short shareable join code.
  code        String      @unique
  hostId      String
  host        User        @relation("RoomHost", fields: [hostId], references: [id], onDelete: Cascade)
  contentType ContentType @default(MOVIE)
  genreIds    Int[]
  status      RoomStatus  @default(ACTIVE)
  createdAt   DateTime    @default(now())
  closedAt    DateTime?

  members RoomMember[]
  swipes  RoomSwipe[]
  matches RoomMatch[]

  @@index([status])
  @@index([hostId])
}

model RoomMember {
  id           String     @id @default(cuid())
  roomId       String
  room         Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         MemberRole @default(MEMBER)
  joinedAt     DateTime   @default(now())
  lastActiveAt DateTime   @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

// A member's vote on a title inside a room.
model RoomSwipe {
  id          String      @id @default(cuid())
  roomId      String
  room        Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId      Int
  contentType ContentType
  action      SwipeAction
  createdAt   DateTime    @default(now())

  @@unique([roomId, userId, tmdbId])
  // Count likes per title in a room to detect matches.
  @@index([roomId, tmdbId])
  @@index([roomId, userId])
}

// A title that enough room members liked — the payoff of a room session.
// Renamed from `Match` in Phase 7 to free that name for friend-scoped matches.
model RoomMatch {
  id          String      @id @default(cuid())
  roomId      String
  room        Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tmdbId      Int
  contentType ContentType
  matchedAt   DateTime    @default(now())

  @@unique([roomId, tmdbId])
  @@index([roomId])
}

// ───────────────────────── Friendships (Phase 7) ─────────────────────────

// Symmetric friendship between two users. We always store (smaller, larger)
// user-id, enforced by a unique index, so (A,B) and (B,A) cannot both exist.
model Friendship {
  id          String   @id @default(cuid())
  userAId     String // smaller cuid (lex order)
  userBId     String // larger cuid
  createdAt   DateTime @default(now())
  inviteToken String? // which invite linked them (audit only)

  userA User @relation("FriendshipA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("FriendshipB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

// A title both friends LIKEd. Stored canonically (userAId < userBId) so the
// pair has exactly one row regardless of who swiped first.
model Match {
  id          String      @id @default(cuid())
  userAId     String // smaller id
  userBId     String // larger id
  tmdbId      Int
  contentType ContentType
  matchedAt   DateTime    @default(now())
  notified    Boolean     @default(false) // push delivered?
  seenByA     Boolean     @default(false) // user A opened it in app
  seenByB     Boolean     @default(false)

  userA User @relation("MatchA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("MatchB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId, tmdbId, contentType])
  @@index([userAId, matchedAt])
  @@index([userBId, matchedAt])
}

// Single-use Telegram deeplink token: t.me/<BOT_USERNAME>?start=<token>
model Invite {
  token      String    @id
  creatorId  String
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  consumedBy String?
  consumedAt DateTime?

  creator User @relation("InviteCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([expiresAt])
}
